\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Sudoku (easy) infill accuracy (\%) on $2{,}000$ held-out puzzles vs.\ the conditioning clean probability $p_\text  {condclean}$, with $95\%$ bootstrap CIs ($10{,}000$ resamples) in brackets. Lower $p$ (more heavily noised clues) yields higher accuracy; the ordering is preserved across data scale. $p{=}1.0$ is the standard ``paste-in'' setup; $p{=}0.0$ is fully unconditional.}}{5}{table.1}\protected@file@percent }
\newlabel{tab:sudoku}{{1}{5}{Sudoku (easy) infill accuracy (\%) on $2{,}000$ held-out puzzles vs.\ the conditioning clean probability $p_\text {condclean}$, with $95\%$ bootstrap CIs ($10{,}000$ resamples) in brackets. Lower $p$ (more heavily noised clues) yields higher accuracy; the ordering is preserved across data scale. $p{=}1.0$ is the standard ``paste-in'' setup; $p{=}0.0$ is fully unconditional}{table.1}{}}
