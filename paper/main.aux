\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces N-Queens infill accuracy and coverage (\%), last checkpoint, $750$ puzzles $\times \,20$ samples, with $95\%$ bootstrap CIs ($10{,}000$ resamples over input boards) in brackets. Coverage is monotonic in $p_\text  {condclean}$ at both scales and $p{=}0.2$ dominates throughout. Note the accuracy non-monotonicity at $n=10$ ($p{=}0.5 < p{=}1.0$); see text.}}{6}{table.2}\protected@file@percent }
\newlabel{tab:nqueens}{{2}{6}{N-Queens infill accuracy and coverage (\%), last checkpoint, $750$ puzzles $\times \,20$ samples, with $95\%$ bootstrap CIs ($10{,}000$ resamples over input boards) in brackets. Coverage is monotonic in $p_\text {condclean}$ at both scales and $p{=}0.2$ dominates throughout. Note the accuracy non-monotonicity at $n=10$ ($p{=}0.5 < p{=}1.0$); see text}{table.2}{}}
